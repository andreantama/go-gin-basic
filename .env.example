# Konfigurasi Aplikasi
# Salin file ini menjadi .env dan sesuaikan nilainya
APP_NAME=go-gin-clean-arch
APP_ENV=development
APP_PORT=8080

# Konfigurasi Database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=go_gin_db

# Konfigurasi JWT
# PENTING: Ganti dengan nilai yang kuat dan acak di production!
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_EXPIRE_HOURS=24
